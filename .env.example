# ===========================================
# YourAuraScore — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# -----------------------------------------------------------------------------
# Public (exposed to the browser)
# -----------------------------------------------------------------------------
# Full URL of your deployed app (e.g. https://youraura.score)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe (payments)
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_..., pk_test_...) for development
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# Required for webhook verification. Create a webhook at:
# https://dashboard.stripe.com/webhooks → Add endpoint → /api/webhook
# Subscribe to: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Printful (merchandise — optional)
# -----------------------------------------------------------------------------
# Get from https://www.printful.com/dashboard/api
# Leave empty if not using merchandise features
# PRINTFUL_API_KEY=
